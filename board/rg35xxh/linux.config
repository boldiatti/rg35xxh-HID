# ARMv8 architecture
CONFIG_ARCH_SUNXI=y
CONFIG_MACH_SUN50I_H6=y
CONFIG_SUN50I_ERRATUM_UNKNOWN1=y

# CPU frequency scaling
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_ARM_CPUIDLE=y
CONFIG_ARM_SUN50I_CPUIDLE=y

# Input devices
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_JOYSTICK_ADC=y
CONFIG_INPUT_TOUCHSCREEN=n
CONFIG_INPUT_MISC=y
CONFIG_INPUT_GPIO_VIBRA=n

# USB Gadget support
CONFIG_USB_GADGET=y
CONFIG_USB_GADGET_VBUS_DRAW=500
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_UEVENT=y
CONFIG_USB_CONFIGFS_ECM=n
CONFIG_USB_CONFIGFS_EEM=n
CONFIG_USB_CONFIGFS_RNDIS=n
CONFIG_USB_CONFIGFS_HID=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_F_ACC=n
CONFIG_USB_F_AUDIO_SRC=n
CONFIG_USB_F_MIDI=n
CONFIG_USB_F_HID=y
CONFIG_USB_F_MASS_STORAGE=n
CONFIG_USB_F_FS=n
CONFIG_USB_U_SERIAL=n

# Bluetooth
CONFIG_BT=y
CONFIG_BT_BREDR=y
CONFIG_BT_RFCOMM=y
CONFIG_BT_RFCOMM_TTY=y
CONFIG_BT_BNEP=y
CONFIG_BT_BNEP_MC_FILTER=y
CONFIG_BT_BNEP_PROTO_FILTER=y
CONFIG_BT_HIDP=y
CONFIG_BT_LE=y
CONFIG_BT_LEDS=y
CONFIG_BT_MSFTEXT=y
CONFIG_BT_AOSPEXT=y
CONFIG_BT_HCIBTUSB=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_BCM=y
CONFIG_BT_HCIUART_RTL=y
CONFIG_BT_HCIRTL=y
CONFIG_BT_RTL=y
CONFIG_BT_HCIUART_3WIRE=y
CONFIG_BT_HCIUART_LL=y
CONFIG_BT_HCIUART_BCSP=y
CONFIG_RTL8723BS=m
CONFIG_RTL8723DS=m

# Display
CONFIG_FB=y
CONFIG_FB_CFB_FILLRECT=y
CONFIG_FB_CFB_COPYAREA=y
CONFIG_FB_CFB_IMAGEBLIT=y
CONFIG_FB_SIMPLE=y
CONFIG_FB_MODE_HELPERS=y
CONFIG_FB_SUNXI=y
CONFIG_DRM=y
CONFIG_DRM_SUN4I=y
CONFIG_DRM_SUN8I_DW_HDMI=y
CONFIG_DRM_SUN8I_MIXER=y

# Power management
CONFIG_POWER_SUPPLY=y
CONFIG_AXP20X_POWER=y
CONFIG_AXP288_CHARGER=n
CONFIG_BATTERY_ACT8945A=n

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="iso8859-1"
CONFIG_TMPFS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y

# Network
CONFIG_PHY_REALTEK=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_SUNXI=y
CONFIG_DWMAC_SUN8I=y
CONFIG_RTL8723BS=m
CONFIG_RTL8723DS=m
CONFIG_RTL8XXXU=m
CONFIG_RTLWIFI=m

# Minimize kernel size
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_KERNEL_LZO=y
CONFIG_SYSTEM_TRUSTED_KEYS=""
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_FS=n
CONFIG_PRINTK_TIME=n